PORT=5000 # порт, на котором мы запускаем бэк, можно изменить
DB_NAME=PadiBoard_DB # измените на название вашей бд в phpmyadmin
DB_USER=root # стандартный логин для phpmyadmin
DB_PASSWORD= # стандартный пароль (в OpenServer обычно root или пусто)
DB_HOST=127.127.126.31 # адрес сервера
DB_PORT=3306 # стандартный порт MySQL
DB_DIALECT=mysql # используемая СУБД

JWT_SECRET=ilovebrbrbr # секретный ключ для шифрования токенов, можно изменить